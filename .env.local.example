NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Note: Supabase dashboard may show this as NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY
# Both refer to the same anon/publishable key

# Optional: service role key for cron jobs (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret to protect cron API routes
CRON_SECRET=your-random-secret-string
